# =========================================================================
# Template de variáveis do rhdp-service (RH/DP — Folha para DRE).
# Copie para `.env` e preencha com valores REAIS (o .env NÃO vai para o git).
# NUNCA commite segredos reais. Rotacione qualquer valor que já tenha vazado.
# =========================================================================

# Connection string do SQL Server (banco BI / DW).
# Formato Prisma sqlserver:
#   sqlserver://HOST:PORTA;database=BANCO;user=USUARIO;password=SENHA;encrypt=true;trustServerCertificate=true
DATABASE_URL=sqlserver://192.168.1.146:1433;database=BI;user=BI_AC;password=SUA_SENHA_AQUI;encrypt=true;trustServerCertificate=true

# Token estático legado da API (compat. com a intranet). DEPRECADO: migrar p/ JWT.
APP_TOKEN=

# --- Autenticação JWT por usuário (mesmo segredo da intranet) ---
JWT_SECRET=
JWT_EXPIRES_IN=12h
# Enquanto 'true', o APP_TOKEN antigo ainda autentica (sem identidade/papel).
LEGACY_APP_TOKEN_ENABLED=true

# Mantenha FALSE em produção (Swagger expõe o mapa de endpoints).
SWAGGER_ENABLED=false

# Origens permitidas para CORS, separadas por vírgula.
CORS_ORIGIN=https://intranet.acacessorios.local

# Porta e URL pública
# Convenção: todos os serviços escutam na 8000 internamente; o proxy reverso
# (EasyPanel) roteia por hostname (pessoal-service.acacessorios.local).
PORT=8000
PUBLIC_URL=https://pessoal-service.acacessorios.local

# Pasta temporária para uploads de PDF da folha.
PASTA_UPLOAD=arquivos/entrada
