generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model CadastroColaboradores {
  id                        Int       @id(map: "PK_CadastroColaboradores") @default(autoincrement())
  matricula                 String?   @db.VarChar(20)
  nome                      String    @db.VarChar(200)
  departamento_folha        String?   @db.VarChar(200)
  cpf                       String?   @db.VarChar(14)
  centro_custo_padrao       String?   @db.VarChar(100)
  tipo_alocacao             String?   @db.VarChar(20)
  percentual_atacado        Decimal?  @default(0.00, map: "DF__CadastroC__perce__762C88DA") @db.Decimal(5, 2)
  percentual_varejo         Decimal?  @default(0.00, map: "DF__CadastroC__perce__7720AD13") @db.Decimal(5, 2)
  percentual_servico        Decimal?  @default(0.00, map: "DF__CadastroC__perce__7814D14C") @db.Decimal(5, 2)
  percentual_corporativo    Decimal?  @default(0.00, map: "DF__CadastroC__perce__7908F585") @db.Decimal(5, 2)
  ativo                     Boolean   @default(true, map: "DF__CadastroC__ativo__79FD19BE")
  observacao                String?   @db.VarChar(1000)
  data_cadastro             DateTime  @default(now(), map: "DF__CadastroC__data___7AF13DF7") @db.DateTime
  data_atualizacao          DateTime? @db.DateTime
  vigencia_inicial          String?   @db.Char(7)
  vigencia_final            String?   @db.Char(7)
  percentual_varejo_servico Decimal?  @default(0.00, map: "DF__CadastroC__perce__093F5D4E") @db.Decimal(5, 2)

  @@index([nome], map: "IX_Colaboradores_Nome")
}

